# Database
DATABASE_URL="mysql://user:password@localhost:3306/hexavante"

# Auth – Better Auth secret key (min 32 chars, generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-key-min-32-chars"

# Redis (usado para cache de sessões, rate-limit, tokens de verificação, OTP)
REDIS_URL="redis://localhost:6379"

# Server
PORT=3045
HOST=0.0.0.0
NODE_ENV=development

# CORS
CORS_ORIGIN="https://hexavante.com,https://app.hexavante.com"

# Rate Limit
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=1 minute
RATE_LIMIT_ALLOW_LIST="127.0.0.1,::1"

# OAuth – Google (opcional)
# Crie credenciais em https://console.cloud.google.com/apis/credentials
# Configure redirect URI: http://localhost:3045/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth – GitHub (opcional)
# Crie credenciais em https://github.com/settings/developers
# Configure redirect URI: http://localhost:3045/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
